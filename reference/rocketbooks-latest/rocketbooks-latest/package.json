{
  "name": "rocketsuite",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node -e \"require('fs').rmSync('.next/dev/lock',{force:true})\" && next dev",
    "dev:locked": "next dev",
    "build": "next build",
    "cf:build": "NEXT_PUBLIC_GIT_COMMIT=$(git rev-parse HEAD) ROCKETSUITE_BUILD_ID=${ROCKETSUITE_BUILD_ID:-$(date -u +%Y%m%dT%H%M%SZ)} opennextjs-cloudflare build",
    "cf:budget": "node scripts/check-worker-bundle-budget.mjs",
    "cf:preview": "NEXT_PUBLIC_GIT_COMMIT=$(git rev-parse HEAD) ROCKETSUITE_BUILD_ID=${ROCKETSUITE_BUILD_ID:-$(date -u +%Y%m%dT%H%M%SZ)} opennextjs-cloudflare build && npm run cf:budget && opennextjs-cloudflare preview",
    "cf:deploy": "NEXT_PUBLIC_GIT_COMMIT=$(git rev-parse HEAD) ROCKETSUITE_BUILD_ID=${ROCKETSUITE_BUILD_ID:-$(date -u +%Y%m%dT%H%M%SZ)} opennextjs-cloudflare build && npm run cf:budget && NEXT_PUBLIC_GIT_COMMIT=$(git rev-parse HEAD) ROCKETSUITE_BUILD_ID=${ROCKETSUITE_BUILD_ID:-$(date -u +%Y%m%dT%H%M%SZ)} wrangler deploy --minify",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:pull": "drizzle-kit pull",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "import-users": "tsx scripts/import-users.ts",
    "perf:routes": "tsx scripts/perf/measure-routes.ts",
    "agent-host": "tsx agent-host/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.156",
    "@daily-co/daily-js": "^0.90.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@opennextjs/cloudflare": "^1.19.11",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/nextjs": "^10.51.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "@tanstack/react-query": "^5.100.8",
    "@tiptap/extension-link": "^3.23.6",
    "@tiptap/react": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "axios": "^1.16.0",
    "drizzle-orm": "^0.45.2",
    "imapflow": "^1.3.3",
    "inngest": "^4.2.6",
    "jose": "^6.2.3",
    "jspdf": "^4.2.1",
    "mailparser": "^3.9.8",
    "next": "16.2.7",
    "nodemailer": "^8.0.9",
    "openai": "^6.35.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.0.227",
    "pino": "^10.3.1",
    "plaid": "^42.2.0",
    "postgres": "^3.4.9",
    "pptxgenjs": "^4.0.1",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-plaid-link": "^4.1.1",
    "read-excel-file": "^9.1.1",
    "recharts": "^3.8.1",
    "resend": "^6.12.3",
    "stripe": "^22.1.1",
    "zod": "^4.4.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20.19.39",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wrangler": "^4.96.0"
  }
}
